# Web app (Next.js) — copy to .env.local

# OpenRouter is supplied by each user in the UI (no server env needed)

# GitHub OAuth (required for "Connect GitHub" button)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Encrypts GitHub tokens in httpOnly cookies (use a long random string)
GITHUB_SESSION_SECRET=replace_with_a_long_random_secret

# Canonical public URL of this app — used to build GitHub OAuth callback URLs.
# Root domain deployment (e.g. openats.shabad.sbs):
NEXT_PUBLIC_APP_URL=https://openats.shabad.sbs
# Subpath deployment (e.g. shabadportfolio.vercel.app/hiring-agent):
# NEXT_PUBLIC_APP_URL=https://shabadportfolio.vercel.app/hiring-agent

# Base path — set ONLY when deploying under a subpath.
# Leave unset (or empty) for root-domain deployments like openats.shabad.sbs.
# NEXT_PUBLIC_BASE_PATH=/hiring-agent

# Local dev (root, no subpath):
# NEXT_PUBLIC_APP_URL=http://localhost:3000
