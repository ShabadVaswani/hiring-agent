# Web app (Next.js) — copy to .env.local

# OpenRouter is supplied by each user in the UI (no server env needed)

# GitHub OAuth (required for "Connect GitHub" button)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Encrypts GitHub tokens in httpOnly cookies (use a long random string)
GITHUB_SESSION_SECRET=replace_with_a_long_random_secret

# Optional: canonical app URL for OAuth callbacks (include base path if set)
# Production: https://shabad.sbs/hiring-agent
# Local dev: http://localhost:3000/hiring-agent
NEXT_PUBLIC_APP_URL=https://shabad.sbs/hiring-agent
